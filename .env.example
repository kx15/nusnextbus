# Copy to .env and fill in real values. Never commit .env (it is gitignored).

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# NUS NextBus API base URL (the legacy/scheduled feed)
NEXTBUS_API_URL=https://nnextbus.nus.edu.sg
# Base64 of "username:password" for the NUS NextBus HTTP Basic Auth.
# Sourced from the NUS NextBus app; required for arrival data.
NEXTBUS_BASIC_AUTH=

# Google Maps API key (Directions, Geocoding, Places). Restrict it to those
# APIs and to your server IP in the Google Cloud console.
GOOGLE_MAPS_API_KEY=

# Optional: SQLite path for favourites (defaults to ./favourites.db)
# DB_PATH=favourites.db

# Optional: Telegram user ID allowed to run admin diagnostics (/debugplan)
# ADMIN_USER_ID=
